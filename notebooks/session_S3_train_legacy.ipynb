   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 5 — Save session (Rule 6)\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "import pandas as pd\n",
    "df = pd.read_csv(RESULTS_CSV)\n",
    "print(f\"Total results: {len(df)} rows | {df['method'].nunique()} methods | {df['dataset'].nunique()} datasets\")\n",
    "print(\"\\n[REMINDER] Click 'Save Version' before session ends.\")\n",
    "print(\"Name the output dataset 'ds-patchmamba-run3' for the next session.\")"
   ]
  }
