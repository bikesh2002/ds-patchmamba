   "source": [
    "# Session S3 — Train DS-PatchMamba on Legacy Datasets\n",
    "\n",
    "**DS-PatchMamba Project | WORKFLOW.md Session S3**\n",
    "\n",
    "**Session target:** ~10–12 GPU-hours\n",
    "\n",
    "**Covers:**\n",
    "- DS-PatchMamba training on SMD × 3 seeds + PSM × 3 seeds\n",
    "- Checkpoint after every epoch (Rule 1)\n",
    "- Score saving immediately after inference (Rule 2)\n",
    "- Row-by-row result appending (Rule 3)\n",
    "- Skip-logic for already-completed runs (Rule 4)\n",
    "- Wall-clock guard: max 10h per session (Rule 7)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 1 — Setup\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "import os, sys, subprocess, shutil\n",
    "\n",
    "# Restore outputs from previous sessions\n",
    "for prev in [\"/kaggle/input/ds-patchmamba-run2\", \"/kaggle/input/ds-patchmamba-run1\"]:\n",
    "    if os.path.exists(prev):\n",
    "        shutil.copytree(prev, \"/kaggle/working/\", dirs_exist_ok=True)\n",
    "        print(f\"Restored from {prev}\")\n",
    "        break\n",
    "\n",
    "for d in [\"results/scores\", \"checkpoints\", \"data\"]:\n",
    "    os.makedirs(d, exist_ok=True)\n",
    "\n",
    "subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\",\n",
    "    \"TSB-AD\", \"statsmodels\", \"scikit-posthocs\",\n",
    "    \"mamba-ssm\", \"causal-conv1d\"], check=False)\n",
    "\n",
    "# Fallback to mamba-minimal if mamba-ssm failed\n",
    "try:\n",
    "    from mamba_ssm import Mamba2\n",
    "    print(\"mamba-ssm available.\")\n",
    "except ImportError:\n",
    "    print(\"mamba-ssm not available. Installing mamba-minimal fallback...\")\n",
    "    subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\",\n",
    "        \"git+https://github.com/johnma2006/mamba-minimal\"], check=False)\n",
    "\n",
    "if \"/kaggle/working\" not in sys.path:\n",
    "    sys.path.insert(0, \"/kaggle/working\")\n",
    "\n",
    "print(\"Setup done.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 2 — Train DS-PatchMamba on SMD × 3 seeds\n",
    "# Expected time: ~4–5h\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "import torch\n",
    "from src.data.loader import load_all_legacy\n",
    "from src.models.ds_patchmamba import DSPatchMamba, ModelConfig, AblationConfig\n",
    "from src.training.trainer import Trainer, load_completed_runs\n",
    "\n",
    "RESULTS_CSV = \"results/main_results.csv\"\n",
    "SCORES_DIR  = \"results/scores\"\n",
    "CKPT_DIR    = \"checkpoints\"\n",
    "\n",
    "cfg = ModelConfig(\n",
    "    patch_size_fine=12, patch_size_coarse=48, window_length=300,\n",
    "    d_model=128, d_state=64, expand=2, d_conv=4, num_heads=4, num_mamba_blocks=2,\n",
    "    d_bottleneck=64,\n",
    ")\n",
    "abl = AblationConfig()  # Full model defaults\n",
    "\n",
    "trainer = Trainer(\n",
    "    cfg=cfg, abl=abl,\n",
    "    results_csv=RESULTS_CSV, scores_dir=SCORES_DIR, ckpt_dir=CKPT_DIR,\n",
    "    max_epochs=50, patience=7, batch_size=64, lr=1e-3,\n",
    "    alpha=0.5, beta=0.01, w=0.5,   # w will be updated after HP tuning in S4\n",
    "    window_length=300, stride=150,\n",
    "    max_train_seconds=36000,        # 10h wall-clock guard\n",
    ")\n",
    "\n",
    "legacy_data = load_all_legacy(\"data\", normalize=True)\n",
    "completed   = load_completed_runs(RESULTS_CSV)\n",
    "\n",
    "SEEDS = [42, 0, 1]\n",
    "\n",
    "for series in legacy_data.get(\"SMD\", []):\n",
    "    for seed in SEEDS:\n",
    "        trainer.run(\n",
    "            series,\n",
    "            method_name=\"DS-PatchMamba\",\n",
    "            dataset_name=\"SMD\",\n",
    "            seed=seed,\n",
    "            ablation_id=\"A10\",\n",
    "            completed_runs=completed,\n",
    "        )\n",
    "\n",
    "print(\"[DONE] SMD training complete.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 3 — Train DS-PatchMamba on PSM × 3 seeds\n",
    "# Expected time: ~4–5h\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "completed = load_completed_runs(RESULTS_CSV)  # Refresh after SMD\n",
    "\n",
    "for series in legacy_data.get(\"PSM\", []):\n",
    "    for seed in SEEDS:\n",
    "        trainer.run(\n",
    "            series,\n",
    "            method_name=\"DS-PatchMamba\",\n",
    "            dataset_name=\"PSM\",\n",
    "            seed=seed,\n",
    "            ablation_id=\"A10\",\n",
    "            completed_runs=completed,\n",
    "        )\n",
    "\n",
    "print(\"[DONE] PSM training complete.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "# CELL 4 — Evaluate scores and verify results\n",
    "# ─────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "from src.evaluation.harness import evaluate_all_saved, get_summary_table\n",
    "\n",
    "# Compute metrics for all saved scores\n",
    "evaluate_all_saved(SCORES_DIR, RESULTS_CSV)\n",
    "\n",
    "# Show summary\n",
    "summary = get_summary_table(RESULTS_CSV, metric=\"vus_pr\")\n",
    "patchmamba = summary[summary[\"method\"] == \"DS-PatchMamba\"]\n",
    "print(patchmamba.to_string())\n",
    "\n",
    "# Critical checkpoint: must beat CNN-AE (~0.31 VUS-PR)\n",
    "# If VUS-PR < 0.25, STOP and debug before running SWaT in S4\n",
    "smd_score = patchmamba[patchmamba[\"dataset\"] == \"SMD\"][\"vus_pr_mean\"].values\n",
    "if len(smd_score) > 0:\n",
    "    print(f\"\\nDS-PatchMamba on SMD: VUS-PR = {smd_score[0]:.4f}\")\n",
    "    if smd_score[0] < 0.25:\n",
    "        print(\"[WARNING] VUS-PR < 0.25. Debug architecture before SWaT.\")\n",
    "    else:\n",
    "        print(\"[OK] Proceeding to SWaT in Session S4.\")"
   ]
  },
  {
   "cell_type": "code",
